# Firebase Config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# LINE Messaging API (Server-side only)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_MY_USER_ID=your_my_line_user_id
LINE_PARTNER_USER_ID=your_partner_line_user_id

# Optional fallback for older setups
# LINE_RECIPIENT_USER_ID=your_partner_line_user_id

# Default sender role for this device: me or partner
NEXT_PUBLIC_MISS_YOU_ROLE=me
